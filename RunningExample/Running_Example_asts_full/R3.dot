		in2_s8 [label="if bpath is not None" fillcolor="#ffe699" fontsize=9 shape=diamond style=filled]
		in2_s9 [label="compare = compare_ele(tree, apath, bpath)" fontsize=9 shape=box]
		in2_s8 -> in2_s9 [label=T]
		in2_s10 [label="if compare == -1" fillcolor="#ffe699" fontsize=9 shape=diamond style=filled]
		in2_s11 [label="return True" fillcolor="#ffb3b3" fontsize=9 shape=box style=filled]
		in2_s10 -> in2_s11 [label=T]
		in2_s12 [label="return False" fillcolor="#ffb3b3" fontsize=9 shape=box style=filled]
		in2_s10 -> in2_s12 [label=F]
		in2_s9 -> in2_s10 [label=""]
		in2_s13 [label="return False" fillcolor="#ffb3b3" fontsize=9 shape=box style=filled]
		in2_s8 -> in2_s13 [label=F]
		in2_s7 -> in2_s8 [label=T]
		in2_s14 [label="return False" fillcolor="#ffb3b3" fontsize=9 shape=box style=filled]
		in2_s7 -> in2_s14 [label=F]
		in2_s6 -> in2_s7 [label=""]
	}
	n2 -> in2_s5 [label=impl color=gray50 style=dashed]
	n1 -> n2
	n15 [label=directly_follows fillcolor=lightblue shape=box style=filled]
	n16 [label="retract consent" fillcolor=lightgreen shape=ellipse style=filled]
	n15 -> n16
	n17 [label=terminate fillcolor=lightgreen shape=ellipse style=filled]
	n15 -> n17
	subgraph cluster_impl_directly_follows_n15 {
		color=gray50 fontname=Helvetica fontsize=10 label="impl: directly_follows" style=dashed
		node [fontname=Helvetica]
		in15_s18 [label="apath = exists(tree, a)" fontsize=9 shape=box]
		in15_s19 [label="bpath = exists(tree, b)" fontsize=9 shape=box]
		in15_s18 -> in15_s19 [label=""]
		in15_s20 [label="if apath is not None" fillcolor="#ffe699" fontsize=9 shape=diamond style=filled]
		in15_s21 [label="if bpath is not None" fillcolor="#ffe699" fontsize=9 shape=diamond style=filled]
		in15_s22 [label="if a == 'terminate'" fillcolor="#ffe699" fontsize=9 shape=diamond style=filled]
		in15_s23 [label="if b == 'terminate'" fillcolor="#ffe699" fontsize=9 shape=diamond style=filled]
		in15_s24 [label="bpaths = tree.findall('.//ns0:terminate', namespace)" fontsize=9 shape=box]
		in15_s23 -> in15_s24 [label=T]
		in15_s25 [label="for bpath in bpaths" fillcolor="#c9e8f0" fontsize=9 shape=diamond style=filled]
		in15_s26 [label="must = directly_follows_must(tree, apath, bpath)" fontsize=9 shape=box]
		in15_s25 -> in15_s26 [label=""]
		in15_s27 [label="if must" fillcolor="#ffe699" fontsize=9 shape=diamond style=filled]
		in15_s28 [label="return True" fillcolor="#ffb3b3" fontsize=9 shape=box style=filled]
		in15_s27 -> in15_s28 [label=T]
		in15_s26 -> in15_s27 [label=""]
		in15_s24 -> in15_s25 [label=""]
		in15_s29 [label="return False" fillcolor="#ffb3b3" fontsize=9 shape=box style=filled]
		in15_s25 -> in15_s29 [label=""]
		in15_s30 [label="must = directly_follows_must(tree, apath, bpath)" fontsize=9 shape=box]
		in15_s23 -> in15_s30 [label=F]
		in15_s31 [label="if must" fillcolor="#ffe699" fontsize=9 shape=diamond style=filled]
		in15_s32 [label="return True" fillcolor="#ffb3b3" fontsize=9 shape=box style=filled]
		in15_s31 -> in15_s32 [label=T]
		in15_s33 [label="can = directly_follows_can(tree, apath, bpath)" fontsize=9 shape=box]
		in15_s31 -> in15_s33 [label=F]
