// AST for R3
digraph {
	fontname=Helvetica fontsize=11 label="R3 [full tree]: parallel('retract consent', 'direct questions') and directly_follows('retract consent', 'terminate')" labelloc=t
	node [fontname=Helvetica fontsize=10]
	edge [fontname=Helvetica fontsize=9]
	n1 [label=and fillcolor=lightyellow shape=diamond style=filled]
	n2 [label=parallel fillcolor=lightblue shape=box style=filled]
	n3 [label="retract consent" fillcolor=lightgreen shape=ellipse style=filled]
	n2 -> n3
	n4 [label="direct questions" fillcolor=lightgreen shape=ellipse style=filled]
	n2 -> n4
	subgraph cluster_impl_parallel_n2 {
		color=gray50 fontname=Helvetica fontsize=10 label="impl: parallel" style=dashed
